DATABASE_URL="file:./dev.db"

# LLM API 配置（使用前填入真实 Key）
LLM_API_KEY="sk-your-api-key-here"
LLM_API_BASE_URL="https://api.deepseek.com"
LLM_MODEL="deepseek-v4-flash"

# 本地音频转写工具（可选，未配置时使用 ~/tools/funasr-diarize）
CHEM_TRACK_DIARIZE_TOOL_DIR="/absolute/path/to/funasr-diarize"

# 项目内 WeComCatch CLI 可通过 WECOMCATCH_CLI_PATH 覆盖。
# 数据迁移前，可指向原 WeComCatch 的运行目录和本地配置。
WECOMCATCH_RUNTIME_DIR="/absolute/path/to/wecomcatch/runtime"
WECOMCATCH_CONFIG_PATH="/absolute/path/to/wecomcatch/config.local.json"
# WECOMCATCH_BUILD_DIR="/absolute/path/to/wecomcatch/build"
# WECOMCATCH_CLI_PATH="/absolute/path/to/wecomcatch/bin/wecomcatch"
